---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import ProjectItem from '../components/ProjectItem.astro';
import ResearchItem from '../components/ResearchItem.astro';
import ProfileSection from '../components/ProfileSection.astro';
import EducationSection from '../components/EducationSection.astro';
import TechGrid from '../components/TechGrid.astro';
import Interests from '../components/Interests.astro';
import { experience, projects, research, education, techGroups } from '../data';

---

<Layout>
  <Nav />
  <div
    class="max-w-6xl mx-auto border-x border-b border-neutral-200 dark:border-neutral-800"
  >
    <!--
      Mobile (<md, flex-col):  order-1 profile → order-2 main → order-3 tech/interests
      Desktop (md+, grid):     col-1 main | col-2 combined sidebar (profile + education + tech + interests)
    -->
    <div class="flex flex-col md:grid md:grid-cols-[1fr_300px]">
      <!-- ── SIDEBAR TOP: profile + education ─────────────────────────────── -->
      <!-- Mobile: first | Desktop: right column, first row -->
      <!-- Mobile-only sidebar top: shown above main content on small screens -->
      <aside
        class="order-1 md:hidden border-b border-neutral-200 dark:border-neutral-800"
      >
        <div class="divide-y divide-neutral-200 dark:divide-neutral-800">
          <ProfileSection variant="mobile" />
          <EducationSection items={education} />
        </div>
      </aside>

      <!-- ── MAIN CONTENT ───────────────────────────────────────────────── -->
      <div
        class="order-2 md:col-start-1 md:row-start-1 md:border-r border-neutral-200 dark:border-neutral-800"
      >
        <!-- Work Experience -->
        <section
          id="experience"
          class="divide-y divide-neutral-200 dark:divide-neutral-800 border-b border-neutral-200 dark:border-neutral-800"
        >
          <div class="px-8 py-8">
            <p
              class="text-xs font-medium uppercase tracking-widest text-emerald-600 dark:text-emerald-400 mb-1.5"
            >
              Career
            </p>
            <h2
              class="text-xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100"
            >
              Work Experience
            </h2>
          </div>
          {experience.map((item) => <ExperienceItem {...item} />)}
        </section>

        <!-- Side Projects -->
        <section
          id="projects"
          class="divide-y divide-neutral-200 dark:divide-neutral-800 border-b border-neutral-200 dark:border-neutral-800"
        >
          <div class="px-8 py-8">
            <p
              class="text-xs font-medium uppercase tracking-widest text-emerald-600 dark:text-emerald-400 mb-1.5"
            >
              Other Work
            </p>
            <h2
              class="text-xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100"
            >
              Side Projects
            </h2>
          </div>
          {projects.map((item) => <ProjectItem {...item} />)}
        </section>

        <!-- Research -->
        <section
          id="research"
          class="divide-y divide-neutral-200 dark:divide-neutral-800"
        >
          <div class="px-8 py-8">
            <p
              class="text-xs font-medium uppercase tracking-widest text-emerald-600 dark:text-emerald-400 mb-1.5"
            >
              Academic
            </p>
            <h2
              class="text-xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100"
            >
              Research
            </h2>
          </div>
          {research.map((item) => <ResearchItem {...item} />)}
        </section>
      </div>

      <!-- ── DESKTOP SIDEBAR: full sidebar, right column (hidden on mobile) ── -->
      <aside
        class="hidden md:block md:col-start-2 md:row-start-1 md:self-start"
      >
        <div class="divide-y divide-neutral-200 dark:divide-neutral-800">
          <ProfileSection variant="desktop" />
          <EducationSection items={education} />
          <TechGrid groups={techGroups} />
          <Interests />
        </div>
      </aside>

      <!-- ── MOBILE SIDEBAR BOTTOM: tech + interests (hidden on desktop) ─── -->
      <aside
        class="order-3 md:hidden border-t border-neutral-200 dark:border-neutral-800"
      >
        <div class="divide-y divide-neutral-200 dark:divide-neutral-800">
          <TechGrid groups={techGroups} />
          <Interests />
        </div>
      </aside>
    </div>

    <footer
      class="border-t border-neutral-200 dark:border-neutral-800 px-8 py-5"
    >
      <p class="text-xs text-neutral-400 dark:text-neutral-600">
        Denis Kustura &copy; {new Date().getFullYear()}
      </p>
    </footer>
  </div>
</Layout>

<script>
  const activeSet = new Set<string>();

  function syncPills() {
    document.querySelectorAll<HTMLElement>('.tech-pill').forEach((el) => {
      const tech = el.dataset.tech;
      el.classList.toggle('active', !!tech && activeSet.has(tech));
    });
  }

  document.querySelectorAll<HTMLElement>('.sidebar-pill').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tech = btn.dataset.tech;
      if (!tech) return;
      activeSet.has(tech) ? activeSet.delete(tech) : activeSet.add(tech);
      syncPills();
    });
  });
</script>
