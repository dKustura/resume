</Layout>

<script>
  const activeSet = new Set<string>();

  function syncPills() {
    document.querySelectorAll<HTMLElement>('.tech-pill').forEach((el) => {
      const tech = el.dataset.tech;
      el.classList.toggle('active', !!tech && activeSet.has(tech));
    });
  }

  document.querySelectorAll<HTMLElement>('.sidebar-pill').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tech = btn.dataset.tech;
      if (!tech) return;
      activeSet.has(tech) ? activeSet.delete(tech) : activeSet.add(tech);
      syncPills();
    });
  });
</script>
