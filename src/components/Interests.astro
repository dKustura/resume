---
import { personal } from '../data';
const { interests } = personal;
---
<div class="px-8 py-8 space-y-3">
  <p class="text-xs font-medium uppercase tracking-widest text-neutral-400 dark:text-neutral-500">
    Interests
  </p>
  <div class="flex flex-wrap gap-x-3 gap-y-1.5">
    {interests.map((item) => (
      <span class="text-xs text-neutral-500 dark:text-neutral-400">{item}</span>
    ))}
  </div>
</div>
