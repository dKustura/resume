---
import { SocialLinks } from '../ui';
import { personal } from '../../data';

interface Props {
  variant: 'mobile' | 'desktop';
}
const { variant } = Astro.props;
---

{variant === 'mobile' && (
  <div class="px-8 py-8">
    <div class="flex items-start gap-4">
      <div class="w-20 h-20 rounded-full overflow-hidden border border-neutral-200 dark:border-neutral-700 bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center shrink-0">
        <img
          src={personal.avatar}
          alt={personal.name}
          class="w-full h-full object-cover"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <span class="text-sm font-semibold text-neutral-400 dark:text-neutral-500 hidden">DK</span>
      </div>
      <div class="flex-1 min-w-0">
        <h1 class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
          {personal.name}
        </h1>
        <p class="text-sm text-emerald-600 dark:text-emerald-400 mt-0.5">
          {personal.title}
        </p>
        <SocialLinks class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-2" />
      </div>
      <button
        type="button"
        class="btn-pop hidden sm:inline-flex shrink-0 items-center gap-2 px-3 py-2 text-sm font-medium rounded-md border border-neutral-200 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Resume
      </button>
    </div>
    <button
      type="button"
      class="btn-pop sm:hidden w-full justify-center inline-flex items-center gap-2 px-4 py-2 mt-4 text-sm font-medium rounded-md border border-neutral-200 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      Resume
    </button>
  </div>
)}

{variant === 'desktop' && (
  <div class="px-8 py-8 space-y-5">
    <div class="w-40 h-40 rounded-full overflow-hidden border border-neutral-200 dark:border-neutral-700 bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center">
      <img
        src={personal.avatar}
        alt={personal.name}
        class="w-full h-full object-cover"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <span class="text-xl font-semibold text-neutral-400 dark:text-neutral-500 hidden">DK</span>
    </div>
    <div>
      <h1 class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
        Denis Kustura
      </h1>
      <p class="text-sm text-emerald-600 dark:text-emerald-400 mt-0.5">
        Senior Software Engineer
      </p>
    </div>
    <SocialLinks />
    <button
      type="button"
      class="btn-pop inline-flex w-full justify-center items-center gap-2 px-4 py-2 text-sm font-medium rounded-md border border-neutral-200 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      Resume
    </button>
  </div>
)}
