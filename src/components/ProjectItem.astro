---
interface Props {
  title: string;
  description?: string;
  period: string;
  tech?: string[];
  link?: string;
}

const { title, description, period, tech = [], link } = Astro.props;
---

<article>
  <div class="px-8 py-7">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <h3 class="font-medium text-neutral-900 dark:text-neutral-100">
        {link ? (
          <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-1 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors"
          >
            {title}
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 group-hover:opacity-60 transition-opacity -mb-px">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        ) : title}
      </h3>
      <p class="text-xs text-neutral-400 dark:text-neutral-500 tabular-nums mt-1 shrink-0">{period}</p>
    </div>

    {description && (
      <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-2 leading-relaxed">{description}</p>
    )}

    {tech.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-4">
        {tech.map((t) => (
          <span
            data-tech={t}
            class="tech-pill px-3 py-1 text-xs rounded-md bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-700 transition-colors cursor-default"
          >
            {t}
          </span>
        ))}
      </div>
    )}
  </div>
</article>
